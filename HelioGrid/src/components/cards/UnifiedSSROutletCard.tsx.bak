// ============================================================================
// UnifiedSSROutletCard.tsx — PATCHED v4.3-safe
//
// PATCHES APPLIED (v4.3 on top of v4.2-safe):
//   [PATCH-OUTLETS] Outlet current/voltage no longer hardcoded (1.2A / 0.8A).
//                   Now uses real sensor data from active source:
//                   - K1 Solar path  → inverterVoltage / inverterCurrent
//                   - K2 Grid path   → gridVoltage / gridCurrent
//                   - Both outlets share the same source; current is split
//                     evenly between however many outlets are currently ON.
//
// PREVIOUS PATCHES (unchanged from v4.2-safe):
//   [FIX-UI-1] Manual lockout indicator
//   [FIX-UI-2] K3 status checks hasPowerSource
//   [FIX-UI-3] Power mode buttons disabled during lockout
//   [FIX-UI-4] Outlet energized requires K1 OR K2
//   [FIX-UI-5] Safety override banner shows specific fault
// ============================================================================

import {
  Power, Zap, AlertCircle, TrendingUp, ArrowLeftRight, Sun,
  Battery, Shield, AlertTriangle, Activity, Lock, Timer, Clock,
} from 'lucide-react';
import { Card, CardContent, CardHeader, CardTitle } from '../ui/card';
import {
  useEnergySystem,
  BAT_WARNING_LOW, BAT_FULL, BAT_CRITICAL_LOW, BAT_CRITICAL_HIGH,
  GRID_NORMAL_LOW, GRID_NORMAL_HIGH, GRID_CRITICAL_LOW, GRID_CRITICAL_HIGH,
  INV_CRITICAL_LOW, INV_CRITICAL_HIGH,
  SOLAR_RATED_W, SOLAR_CRITICAL_LOW, SOLAR_WARNING_LOW,
  K3_RECONNECT_DELAY_MS,
} from '../../contexts/EnergySystemContext';

export function UnifiedSSROutletCard() {
  const {
    controlMode, controlAuthority, autoSwitchEnabled, setAutoSwitchEnabled,
    manualBlockedReason, enterManualMode, exitManualMode,
    outlet1Status, outlet2Status, setOutlet1Status, setOutlet2Status,
    gridVoltage, gridFrequency, gridAnomaly,
    gridCurrent,                               // [PATCH-OUTLETS] real grid current
    inverterVoltage, inverterFrequency, inverterAnomaly,
    inverterCurrent,                           // [PATCH-OUTLETS] real inverter current
    batteryVoltage, batterySOC, batteryAnomaly, batteryFull,
    ssrStates, k4Closed, k3Active, k3Direction, k3Reconnect,
    totalSwitches, lastSwitchTime,
    solarPower, solarAnomaly, systemCondition,
    tempAnomaly, sensorIntegrity,              // [FIX-GAP-3] for clear override check
    refreshData,
    manualLockoutRemaining,                    // [FIX-UI-1]
    batteryBankBAvailable,
  } = useEnergySystem();

  const isManual         = controlAuthority === 'manual';
  const isSafetyOverride = controlAuthority === 'safety_override';
  const isAuto           = controlAuthority === 'auto';

  const K1_Solar  = ssrStates.K1;
  const K2_Grid   = ssrStates.K2;
  const K3_GridAssist = k3Active;
  const K4_Closed = k4Closed;
  const K4_Open   = !K4_Closed;

  // [FIX-UI-1] Is auto temporarily suppressed?
  const lockoutActive = manualLockoutRemaining > 0;

  // [FIX-GAP-3] True when safety_override is active but ALL critical faults have cleared
  // — this is the signal to show the "Clear Override" button so user can recover
  const faultsCleared = isSafetyOverride && (
    gridAnomaly !== 'critical' &&
    inverterAnomaly !== 'critical' &&
    batteryAnomaly !== 'critical' &&
    solarAnomaly !== 'critical' &&
    (tempAnomaly ?? 'none') !== 'critical' &&
    (sensorIntegrity ?? 'none') !== 'critical'
  );

  const inverterReady =
    inverterVoltage >= INV_CRITICAL_LOW && inverterVoltage <= INV_CRITICAL_HIGH &&
    inverterFrequency >= 59 && inverterFrequency <= 61 &&
    inverterAnomaly === 'none';

  const gridReady =
    gridVoltage >= GRID_NORMAL_LOW && gridVoltage <= GRID_NORMAL_HIGH &&
    gridFrequency >= 59 && gridFrequency <= 61 &&
    gridAnomaly === 'none';

  const batteryWarning       = batteryVoltage > 0 && batteryVoltage < BAT_WARNING_LOW && batteryAnomaly !== 'critical';
  const batteryOvercharge    = batteryVoltage > BAT_CRITICAL_HIGH;
  const batteryDeepDischarge = batteryVoltage > 0 && batteryVoltage < BAT_CRITICAL_LOW;

  const solarCritical = solarPower > 0 && solarPower < SOLAR_CRITICAL_LOW;
  const solarWarning  = solarPower > 0 && solarPower >= SOLAR_CRITICAL_LOW && solarPower < SOLAR_WARNING_LOW;
  const solarPct      = Math.round((solarPower / SOLAR_RATED_W) * 100);

  // [FIX-UI-4] Correct outlets energized logic — must have K4 AND (K1 OR K2)
  const outletEnergized = K4_Closed && (K1_Solar || K2_Grid);

  // [FIX-UI-2] K3 display only makes sense when there is a power source
  const hasPowerSource = K1_Solar || K2_Grid;

  const manilaHour    = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Manila' })).getHours();
  const isHarvestTime = manilaHour >= 6 && manilaHour < 18;
  const isNight       = !isHarvestTime;
  const batteryLow    = batteryVoltage > 0 && batteryVoltage < BAT_WARNING_LOW && batteryAnomaly !== 'critical';
  const solarLowDay   = isHarvestTime && solarPower > 0 && solarPower < SOLAR_CRITICAL_LOW;
  const solarZeroDay  = isHarvestTime && solarPower === 0;

  const k3IsAssist = K3_GridAssist && k3Direction === 'assist' && hasPowerSource;  // [FIX-UI-2]
  const k3IsCharging = K3_GridAssist && k3Direction === 'charging' && hasPowerSource;  // [FIX-UI-2]

  const k3ModeLabel = k3Reconnect.locked
    ? `LOCKED — ${k3Reconnect.secondsRemaining}s`
    : !K3_GridAssist ? 'STANDBY'
    : !hasPowerSource ? 'STANDBY (no source)'
    : k3IsCharging ? 'GRID CHARGING'
    : 'GRID ASSISTING';

  // [FIX-RPI-LOAD] No grid scenarios — battery sustaining load
  const noGrid = gridAnomaly === 'critical' || gridVoltage === 0;

  const k3DirectionLabel = k3Reconnect.locked
    ? `⏱ Reconnect timer: ${k3Reconnect.secondsRemaining}s remaining`
    : !K3_GridAssist ? 'Auto only'
    : !hasPowerSource ? 'Waiting for K1 or K2'
    : k3IsCharging   ? '→ Battery (surplus PV)'
    : isNight      ? '← Grid (night charge)'
    : solarLowDay  ? '← Grid (cloudy/rain)'
    : solarZeroDay ? '← Grid (no solar)'
    : batteryLow   ? '← Grid (bat low)'
    : '← Grid';

  // [FIX-UI-5] Determine which fault caused safety override
  // [FIX-RPI-LOAD] Status label when battery is sustaining load (no grid)
  const batterySustainingLabel = noGrid && batteryLow
    ? `⚠️ No Grid — Battery Sustaining Load (${batteryVoltage.toFixed(1)}V)`
    : noGrid && !batteryLow
    ? `Grid Outage — Battery Sustaining Load (${batteryVoltage.toFixed(1)}V)`
    : null;

  const overrideFaultLabel = (() => {
    if (inverterAnomaly === 'critical' && gridAnomaly === 'critical')
      return 'Double Fault — Inverter + Grid. Battery sustaining load. Admin must inspect.';
    if (inverterAnomaly === 'critical')
      return `Inverter ${inverterVoltage.toFixed(1)}V out of range — switched to Grid bypass (K2).`;
    if (gridAnomaly === 'critical')
      return `Grid ${gridVoltage.toFixed(1)}V out of safe range — isolated K2+K3, solar island.`;
    if (batteryAnomaly === 'critical')
      return `Battery ${batteryVoltage.toFixed(1)}V critical — Inverter+MCCB protecting. Admin alert sent.`;
    return 'P1 Critical Fault active — relay control locked.';
  })();

  // [PATCH-OUTLETS] Real source voltage & current based on active path
  const activeSourceVoltage  = K1_Solar ? inverterVoltage : K2_Grid ? gridVoltage : 0;
  const activeSourceCurrent  = K1_Solar ? (inverterCurrent ?? 0) : K2_Grid ? (gridCurrent ?? 0) : 0;

  // Split current evenly between however many outlets are currently ON
  const activeOutletCount = outletEnergized ? 2 : 0;
  const perOutletCurrent =
    activeOutletCount > 0 && outletEnergized
      ? activeSourceCurrent / Math.max(activeOutletCount, 1)
      : 0;

  const outlets = [
    {
      id: 1, name: 'Outlet 1', load: 'Laptop',
      status: outletEnergized,
      source: K1_Solar ? 'Solar (K1)' : K2_Grid ? 'Grid (K2)' : 'OFF',
      hasAnomaly: (gridAnomaly !== 'none' && K2_Grid) || (inverterAnomaly !== 'none' && K1_Solar),
      current: outletEnergized ? perOutletCurrent : 0,
      voltage: outletEnergized ? activeSourceVoltage : 0,
    },
    {
      id: 2, name: 'Outlet 2', load: 'Monitor',
      status: outletEnergized,
      source: K1_Solar ? 'Solar (K1)' : K2_Grid ? 'Grid (K2)' : 'OFF',
      hasAnomaly: (gridAnomaly !== 'none' && K2_Grid) || (inverterAnomaly !== 'none' && K1_Solar),
      current: outletEnergized ? perOutletCurrent : 0,
      voltage: outletEnergized ? activeSourceVoltage : 0,
    },
  ];

  const toggleOutlet = (id: number): void => {
    if (!outletEnergized) return;
    if (id === 1) setOutlet1Status(!outlet1Status);
    else          setOutlet2Status(!outlet2Status);
  };

  // [FIX-UI-3] Block mode change during lockout
  const handleModeChange = (mode: 'solar' | 'grid' | 'shutdown'): void => {
    if (isAuto) return;
    if (isSafetyOverride) return;
    if (lockoutActive) return;
    enterManualMode(mode);
  };

  const handleEmergency = async (): Promise<void> => {
    // Emergency cutoff — sends 'X' to Arduino via Flask /api/ssr/emergency
    // Bypasses all interlocks: K4 opens first, then all relays OFF
    // No confirmation dialog — immediate action for safety
    // [FIX-EMERGENCY-SYNC] Immediately switch to manual+shutdown in Context
    // so UI reflects emergency state without waiting for 2s poll.
    enterManualMode('shutdown');
    try {
      await fetch('/api/ssr/emergency', { method: 'POST' });
    } catch (err) {
      console.error('Emergency cutoff request failed:', err);
    }
  };

  const handleAutoSwitchToggle = (enabled: boolean): void => {
    if (isSafetyOverride) return;
    if (lockoutActive) return;   // [FIX-GAP-1] block toggle during relay settling
    if (enabled) {
      exitManualMode();
    } else {
      setAutoSwitchEnabled(false);
    }
  };

  const authorityBadge = isSafetyOverride
    ? { text: 'Safety Override', cls: 'bg-red-100 text-red-700 border-red-400' }
    : isManual
    ? { text: lockoutActive ? `Manual (${manualLockoutRemaining}s)` : 'Manual',
        cls: 'bg-amber-100 text-amber-700 border-amber-400' }
    : lockoutActive
    ? { text: `Auto (settling ${manualLockoutRemaining}s)`,
        cls: 'bg-blue-100 text-blue-700 border-blue-400' }
    : { text: 'Auto', cls: 'bg-green-100 text-green-700 border-green-400' };

  const modeDescription: Record<string, string> = {
    solar:    'Solar Priority — Inverter → K1 → ATS-A → Outlets',
    grid:     'Grid Bypass — Grid → K2 → ATS-B → Outlets',
    assist:   'Grid Assist — Grid supplements solar/battery via K3',
    failsafe: 'Failsafe — Island Mode (K4 CLOSED, no AC input, battery via inverter)',
    shutdown: 'Load Cut Off — K4 OPEN, outlets disconnected. Trip MCCB if battery fault.',
  };

  return (
    <Card className="border-slate-200 shadow-lg hover:shadow-xl transition-shadow">
      <CardHeader className="pb-3">
        <CardTitle className="flex items-center justify-between text-sm sm:text-base">
          <div className="flex items-center gap-2">
            <div className="p-2 rounded-lg" style={{background:'linear-gradient(to bottom right, #f3e8ff, #cffafe)'}}>
              <ArrowLeftRight className="w-4 h-4 sm:w-5 sm:h-5 text-purple-600" />
            </div>
            <span>SSR Control &amp; Outlet Management</span>
          </div>
          <div className="flex items-center gap-2">
            <span className={`px-2 py-0.5 rounded-full text-xs border font-medium ${authorityBadge.cls}`}>
              {authorityBadge.text}
            </span>
            <div
              title={K4_Open ? 'K4 OPEN — Outlets disconnected (Load Cut Off mode)'
                : controlMode === 'failsafe' ? 'K4 CLOSED — Island mode'
                : 'K4 CLOSED — Outlets connected'}
              className={`w-2.5 h-2.5 rounded-full ${
                K4_Open ? 'bg-red-500 animate-pulse'
                : controlMode === 'failsafe' ? 'bg-orange-400'
                : 'bg-green-500'}`}
            />
          </div>
        </CardTitle>
      </CardHeader>

      <CardContent className="space-y-4">

        {/* [FIX-UI-5] Safety Override Banner */}
        {isSafetyOverride && (
          <div className="p-3 rounded-lg bg-red-50 border-2 border-red-400 flex items-center gap-2">
            <Lock className="w-5 h-5 text-red-600 shrink-0" />
            <div className="flex-1">
              <div className="text-sm font-bold text-red-800">Safety Override Active</div>
              <div className="text-xs text-red-700 mt-0.5">{overrideFaultLabel}</div>
              {faultsCleared ? (
                <div className="text-xs text-green-700 mt-0.5 font-semibold">
                  ✅ All faults cleared — safe to resume auto control.
                </div>
              ) : (
                <div className="text-xs text-red-600 mt-0.5">
                  Manual control locked. Returns to Auto when all P1 faults clear.
                </div>
              )}
            </div>
            {faultsCleared && (
              <button
                onClick={() => exitManualMode()}
                className="ml-2 px-3 py-1.5 rounded-lg bg-green-600 hover:bg-green-700 text-white text-xs font-semibold transition-colors shrink-0"
              >
                Clear Override
              </button>
            )}
          </div>
        )}

        {/* [FIX-UI-1] Manual lockout countdown banner */}
        {lockoutActive && !isSafetyOverride && (
          <div className="p-3 rounded-lg bg-blue-50 border border-blue-300 flex items-center gap-2">
            <Clock className="w-4 h-4 text-blue-500 shrink-0" />
            <span className="text-xs text-blue-700">
              ⏳ Relay settling — auto-switch resumes in <strong>{manualLockoutRemaining}s</strong>.
              Mode buttons locked during settling period.
            </span>
          </div>
        )}

        {manualBlockedReason && (
          <div className="p-3 rounded-lg bg-orange-50 border border-orange-300 flex items-center gap-2">
            <AlertCircle className="w-4 h-4 text-orange-500 shrink-0" />
            <span className="text-xs text-orange-700">⛔ {manualBlockedReason}</span>
          </div>
        )}

        {/* K3 Reconnect Timer Banner */}
        {k3Reconnect.locked && (
          <div className="p-3 rounded-lg bg-cyan-50 border-2 border-cyan-400 flex items-center gap-3">
            <Timer className="w-5 h-5 text-cyan-600 shrink-0" />
            <div className="flex-1">
              <div className="text-sm font-bold text-cyan-800">K3 Reconnect Timer</div>
              <div className="text-xs text-cyan-700 mt-0.5">
                Grid recovered from fault. K3 locked for {k3Reconnect.secondsRemaining}s.
                Timer resets if grid fluctuates.
              </div>
            </div>
            <div className="text-2xl font-mono font-bold text-cyan-700 min-w-[3rem] text-right">
              {Math.floor(k3Reconnect.secondsRemaining / 60).toString().padStart(2, '0')}:
              {(k3Reconnect.secondsRemaining % 60).toString().padStart(2, '0')}
            </div>
          </div>
        )}

        {controlMode === 'failsafe' && (
          <div className="p-3 rounded-lg bg-orange-50 border-2 border-orange-400 flex items-center gap-2">
            <Shield className="w-5 h-5 text-orange-600 shrink-0" />
            <div>
              <div className="text-sm font-bold text-orange-800">Failsafe — Island Mode</div>
              <div className="text-xs text-orange-700 mt-0.5">
                K4 CLOSED — Battery via inverter. No AC input. Awaiting recovery.
              </div>
            </div>
          </div>
        )}

        {controlMode === 'shutdown' && (
          <div className="p-3 rounded-lg bg-red-50 border-2 border-red-500 flex items-center gap-2">
            <AlertTriangle className="w-5 h-5 text-red-600 shrink-0" />
            <div>
              <div className="text-sm font-bold text-red-800">Load Cut Off — K4 OPEN</div>
              <div className="text-xs text-red-700 mt-0.5">
                Outlets physically disconnected. Trip MCCB if battery fault persists.
              </div>
            </div>
          </div>
        )}

        {batteryDeepDischarge && (
          <div className="p-3 rounded-lg bg-red-50 border-2 border-red-400 flex items-center gap-2">
            <Battery className="w-4 h-4 text-red-600 shrink-0" />
            <span className="text-xs text-red-800 font-semibold">
              🔴 Deep Discharge — {batteryVoltage.toFixed(1)}V &lt; {BAT_CRITICAL_LOW}V.
              Inverter protection active. Trip MCCB if inverter fails.
            </span>
          </div>
        )}

        {batteryOvercharge && (
          <div className="p-3 rounded-lg bg-red-50 border-2 border-red-400 flex items-center gap-2">
            <Battery className="w-4 h-4 text-red-600 shrink-0" />
            <span className="text-xs text-red-800 font-semibold">
              🔴 Overcharge — {batteryVoltage.toFixed(1)}V &gt; {BAT_CRITICAL_HIGH}V.
              Inverter protection active. Trip MCCB if inverter fails.
            </span>
          </div>
        )}

        {batteryWarning && (
          <div className="p-3 rounded-lg bg-yellow-50 border-2 border-yellow-400 flex items-center gap-2">
            <Battery className="w-4 h-4 text-yellow-600 shrink-0" />
            <div>
              <span className="text-xs text-yellow-800 font-semibold">
                ⚠ Battery Low — {batteryVoltage.toFixed(1)}V ({batterySOC.toFixed(0)}%) &lt; {BAT_WARNING_LOW}V
              </span>
              <div className="text-xs text-yellow-700 mt-0.5">
                Auto-switched to Grid ({lastSwitchTime}). K3 Grid Assist activated. Battery charging.
              </div>
            </div>
          </div>
        )}

        {solarCritical && (
          <div className="p-3 rounded-lg bg-orange-50 border-2 border-orange-400 flex items-center gap-2">
            <Sun className="w-4 h-4 text-orange-600 shrink-0" />
            <div>
              <span className="text-xs text-orange-800 font-semibold">
                🔴 Solar Critical — {solarPower.toFixed(0)}W &lt; {SOLAR_CRITICAL_LOW}W ({solarPct}% rated)
              </span>
              <div className="text-xs text-orange-700 mt-0.5">K3 Grid Assist activated for battery charging.</div>
            </div>
          </div>
        )}

        {solarWarning && !solarCritical && (
          <div className="p-3 rounded-lg bg-amber-50 border border-amber-300 flex items-center gap-2">
            <Sun className="w-4 h-4 text-amber-600 shrink-0" />
            <span className="text-xs text-amber-800">
              ⚠ Solar Low — {solarPower.toFixed(0)}W &lt; {SOLAR_WARNING_LOW}W ({solarPct}%).
              Check panels for shading or dust.
            </span>
          </div>
        )}

        {/* ── AUTO-SWITCHING ── */}
        <div className="p-4 rounded-xl border-2 border-green-300 shadow-md" style={{background:'linear-gradient(to bottom right, #f0fdf4, #ecfdf5)'}}>
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="p-2 rounded-lg bg-green-100">
                <Activity className="w-5 h-5 text-green-600" />
              </div>
              <div>
                <div className="text-sm sm:text-base font-semibold text-green-900">Auto-Switching</div>
                <p className="text-xs text-green-700 mt-0.5">
                  {isSafetyOverride ? 'Safety override — locked until P1 clears'
                    : lockoutActive ? `Settling after manual command — ${manualLockoutRemaining}s`
                    : isAuto ? `Arduino monitoring — ${systemCondition}`
                    : 'Manual control — auto-switch suspended (30min timeout)'}
                </p>
              </div>
            </div>
            <button
              onClick={() => handleAutoSwitchToggle(!isAuto)}
              disabled={isSafetyOverride || lockoutActive}
              className={`relative w-16 h-8 sm:w-20 sm:h-10 rounded-full transition-all duration-300
                ${isAuto ? 'bg-green-500 shadow-lg' : 'bg-gray-300'}
                ${(isSafetyOverride || lockoutActive) ? 'opacity-50 cursor-not-allowed' : ''}`}>
              <div className={`absolute top-1 w-6 h-6 sm:w-8 sm:h-8 bg-white rounded-full shadow-md transition-transform duration-300
                ${isAuto ? 'translate-x-9 sm:translate-x-11' : 'translate-x-1'}`} />
            </button>
          </div>
          {isManual && !isSafetyOverride && (
            <div className="mt-3 px-3 py-1.5 rounded-lg bg-amber-100 border border-amber-300 flex items-center gap-2">
              <AlertTriangle className="w-4 h-4 text-amber-600 shrink-0" />
              <span className="text-xs text-amber-700">
                Manual Mode — safety protections still active. Auto-timeout in 30 min.
              </span>
            </div>
          )}
        </div>

        {/* ── POWER MODE ── */}
        <div className="p-4 rounded-xl border-2 border-indigo-300 shadow-md" style={{background:'linear-gradient(to bottom right, #eef2ff, #faf5ff, #eff6ff)'}}>
          <div className="flex items-center justify-between mb-3">
            <div className="flex items-center gap-2">
              <Shield className="w-5 h-5 text-indigo-600" />
              <span className="text-sm sm:text-base text-indigo-900 font-semibold">Power Control Mode</span>
            </div>
            <div className={`px-3 py-1 rounded-full text-xs sm:text-sm font-semibold ${
              // [FIX-SHUTDOWN] Use K4_Closed to determine actual active mode display
              K4_Open                                    ? 'bg-red-600 text-white'    :
              controlMode === 'solar'                    ? 'bg-amber-500 text-white'  :
              controlMode === 'grid'                     ? 'bg-blue-500 text-white'   :
              controlMode === 'failsafe'                 ? 'bg-orange-500 text-white' : 'bg-red-600 text-white'}`}>
              {K4_Open                    ? 'Load Cut Off — K4 OPEN'
               : controlMode === 'solar'    ? 'Solar — K1'
               : controlMode === 'grid'     ? 'Grid — K2'
               : controlMode === 'failsafe' ? 'Failsafe — Island'
               : 'Load Cut Off — K4 OPEN'}
              {K3_GridAssist && hasPowerSource && <span className="ml-1 text-[0.65rem] bg-white/30 px-1 rounded">+K3</span>}
            </div>
          </div>

          {/* [FIX-UI-3] Buttons disabled during lockout */}
          <div className="grid grid-cols-3 gap-1.5 sm:gap-3">
            {[
              {
                mode: 'solar' as const, label: 'Solar', sub: 'K1',
                icon: Sun, ready: inverterReady,
                readyLabel: inverterReady ? '✓ Ready' : '⚠ Check',
                // [FIX-SHUTDOWN] active only if controlMode=solar AND K4 is closed
                active: controlMode === 'solar' && K4_Closed,
                activeClass: 'bg-amber-500 border-amber-600',
                hoverClass: 'hover:border-amber-300',
              },
              {
                mode: 'grid' as const, label: 'Grid', sub: 'K2',
                icon: Zap, ready: gridReady,
                readyLabel: gridReady ? '✓ Stable' : '⚠ Unstable',
                // [FIX-SHUTDOWN] active only if controlMode=grid AND K4 is closed
                active: (controlMode === 'grid' || controlMode === 'failsafe') && K4_Closed,
                activeClass: 'bg-blue-500 border-blue-600',
                hoverClass: 'hover:border-blue-300',
              },
            ].map(btn => (
              <button key={btn.mode}
                onClick={() => handleModeChange(btn.mode)}
                disabled={isAuto || isSafetyOverride || lockoutActive}
                className={`p-2 sm:p-3 rounded-lg border-2 transition-all text-center
                  ${btn.active ? `${btn.activeClass} text-white shadow-lg`
                    : `bg-white border-slate-200 text-slate-700 ${btn.hoverClass}`}
                  ${isAuto || isSafetyOverride || lockoutActive
                    ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer active:scale-95'}`}>
                <btn.icon className="w-3.5 h-3.5 sm:w-4 sm:h-4 mx-auto mb-1" />
                <div className="text-[0.65rem] sm:text-xs font-bold">{btn.label}</div>
                <div className="text-[0.55rem] sm:text-[0.6rem] font-semibold mt-0.5">{btn.sub}</div>
                <div className={`text-[0.55rem] sm:text-[0.6rem] mt-1 ${btn.ready ? 'text-green-600' : 'text-red-500'}`}>
                  {btn.readyLabel}
                </div>
              </button>
            ))}
            <button
              onClick={() => handleModeChange('shutdown')}
              disabled={isAuto || isSafetyOverride || lockoutActive}
              className={`p-3 rounded-lg border-2 transition-all text-center
                ${controlMode === 'shutdown'
                  ? 'bg-red-500 border-red-600 text-white shadow-lg'
                  : 'bg-white border-slate-200 text-slate-700 hover:border-red-300'}
                ${isAuto || isSafetyOverride || lockoutActive
                  ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer active:scale-95'}`}>
              <AlertTriangle className="w-4 h-4 mx-auto mb-1" />
              <div className="text-xs font-bold">Load Cut Off</div>
              <div className="text-[0.6rem] font-semibold mt-0.5">K4 OPEN</div>
              <div className="text-[0.6rem] mt-1 opacity-70">Loads cut</div>
            </button>
          </div>

          {/* Emergency Cutoff — same style as Solar/Grid/Shutdown buttons */}
          <button
            onClick={() => handleEmergency()}
            disabled={isAuto || isSafetyOverride || lockoutActive}
            className={`w-full mt-1 p-3 rounded-lg border-2 transition-all text-center
              ${!isAuto && !isSafetyOverride && !lockoutActive
                ? 'bg-red-600 border-red-700 text-white shadow-lg hover:bg-red-700'
                : 'bg-white border-slate-200 text-slate-700 hover:border-red-300'}
              ${isAuto || isSafetyOverride || lockoutActive
                ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer active:scale-95'}`}>
            <AlertTriangle className="w-3.5 h-3.5 sm:w-4 sm:h-4 mx-auto mb-1" />
            <div className="text-[0.65rem] sm:text-xs font-bold">Emergency</div>
            <div className="text-[0.55rem] sm:text-[0.6rem] font-semibold mt-0.5">Shutdown</div>
            <div className="text-[0.55rem] sm:text-[0.6rem] mt-1 text-red-300">
              {isAuto ? 'Manual only' : 'All relays OFF instantly'}
            </div>
          </button>

          {/* K3 Status Bar */}
          <div className={`mt-3 px-3 py-2 rounded-lg border text-xs flex items-center gap-2 ${
            k3Reconnect.locked ? 'bg-cyan-50 border-cyan-300 text-cyan-800'
            : K3_GridAssist && hasPowerSource ? 'bg-teal-50 border-teal-300 text-teal-800'
            : batteryWarning || solarCritical ? 'bg-orange-50 border-orange-300 text-orange-800'
            : 'bg-slate-50 border-slate-200 text-slate-500'}`}>
            {k3Reconnect.locked && <Timer className="w-3 h-3 shrink-0" />}
            <div>
              <span className="font-semibold">K3 Grid Assist / Charging (auto only): </span>
              {k3Reconnect.locked
                ? `⏱ Reconnect timer: ${k3Reconnect.secondsRemaining}s — grid must be stable for 5 min`
                : k3IsCharging
                  ? `⚡ GRID CHARGING — Battery ${batteryVoltage.toFixed(1)}V · PV ${solarPower.toFixed(0)}W surplus`
                : k3IsAssist && isNight
                  ? `⚡ GRID ASSISTING — Night charging · Battery ${batteryVoltage.toFixed(1)}V`
                : k3IsAssist && (solarLowDay || solarZeroDay)
                  ? `⚡ GRID ASSISTING — ${solarZeroDay ? 'No solar' : `Solar low ${solarPower.toFixed(0)}W`} · Battery ${batteryVoltage.toFixed(1)}V`
                : k3IsAssist
                  ? `⚡ GRID ASSISTING — Battery low ${batteryVoltage.toFixed(1)}V`
                : !hasPowerSource && K3_GridAssist
                  ? `Waiting for K1 or K2 — no power source active`
                : batteryFull
                  ? `Standby — battery full, waiting for surplus PV`
                  : `Standby — Battery ${batteryVoltage.toFixed(1)}V · K3 activates on low bat or surplus PV`}
            </div>
          </div>
        </div>

        {/* ── RELAY STATUS INDICATORS ── */}
        <div className="grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-3">
          {[
            {
              label: 'K4 (Contactor)',
              active: K4_Closed,
              color: K4_Open ? 'bg-red-100 border-red-400'
                : controlMode === 'failsafe' ? 'bg-orange-100 border-orange-400'
                : 'bg-green-50 border-green-300',
              dot: K4_Open ? 'bg-red-500 animate-pulse'
                : controlMode === 'failsafe' ? 'bg-orange-400' : 'bg-green-500',
              status: K4_Open ? 'OPEN' : controlMode === 'failsafe' ? 'CLOSED (island)' : 'CLOSED',
              sub: K4_Open ? 'Outlets cut' : controlMode === 'failsafe' ? 'No AC input' : 'Outlets connected',
            },
            {
              label: 'K1 (Solar)',
              active: K1_Solar,
              color: K1_Solar ? 'bg-amber-100 border-amber-400' : 'bg-slate-100 border-slate-300',
              dot: K1_Solar ? 'bg-amber-500 animate-pulse' : 'bg-slate-400',
              status: K1_Solar ? 'SOLAR ON' : 'OFF',
              sub: K1_Solar ? 'Inv→ATS-A→Load' : 'Standby',
            },
            {
              label: 'K2 (Grid)',
              active: K2_Grid,
              color: K2_Grid ? 'bg-blue-100 border-blue-400' : 'bg-slate-100 border-slate-300',
              dot: K2_Grid ? 'bg-blue-500 animate-pulse' : 'bg-slate-400',
              status: K2_Grid ? 'GRID ON' : 'OFF',
              sub: K2_Grid ? 'Grid→ATS-B→Load' : 'Standby',
            },
            {
              label: 'K3 (Grid Assist)',
              active: K3_GridAssist && hasPowerSource,
              color: k3Reconnect.locked ? 'bg-cyan-100 border-cyan-400'
                : K3_GridAssist && hasPowerSource ? 'bg-teal-100 border-teal-400'
                : 'bg-slate-100 border-slate-300',
              dot: k3Reconnect.locked ? 'bg-cyan-500 animate-pulse'
                : K3_GridAssist && hasPowerSource ? 'bg-teal-500 animate-pulse'
                : 'bg-slate-400',
              status: k3ModeLabel,
              sub: k3DirectionLabel,
            },
          ].map((r, i) => (
            <div key={i} className={`p-3 rounded-lg border-2 ${r.color}`}>
              <div className="text-center">
                <div className="text-xs text-slate-600 mb-1">{r.label}</div>
                <div className={`w-4 h-4 mx-auto rounded-full ${r.dot}`} />
                <div className="text-[0.65rem] text-slate-600 mt-1 font-semibold">{r.status}</div>
                <div className="text-[0.55rem] text-slate-500 mt-0.5">{r.sub}</div>
              </div>
            </div>
          ))}
        </div>

        {/* ── SSR POWER PATHWAYS ── */}
        <div className="rounded-xl border-2 border-cyan-300 overflow-hidden">
          <div className="flex items-center gap-2 px-4 py-3" style={{background:'linear-gradient(to right, #0891b2, #2563eb)'}}>
            <ArrowLeftRight className="w-4 h-4 text-white" />
            <span className="text-sm text-white font-medium">SSR Power Pathways</span>
            <span className="ml-auto text-[0.65rem] bg-white/20 text-white px-2 py-0.5 rounded-full">
              Lead Acid Gel 24V · {batteryBankBAvailable ? '200Ah' : '100Ah'} {batteryBankBAvailable ? '(Bank A+B)' : '(Bank A)'}
            </span>
          </div>

          <div className="divide-y divide-cyan-100 bg-white">
            {/* K4 */}
            <div className="flex items-start gap-3 px-4 py-3 hover:bg-cyan-50 transition-colors">
              <div className={`mt-0.5 w-8 h-8 rounded-full flex items-center justify-center shrink-0
                ${K4_Open ? 'bg-red-100' : controlMode === 'failsafe' ? 'bg-orange-100' : 'bg-green-100'}`}>
                <Power className={`w-4 h-4 ${K4_Open ? 'text-red-600' : controlMode === 'failsafe' ? 'text-orange-600' : 'text-green-600'}`} />
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 flex-wrap">
                  <span className="text-xs font-bold text-slate-800">K4</span>
                  <span className="text-[0.6rem] px-1.5 py-0.5 rounded bg-slate-100 text-slate-600">ATS Output → Contactor → Outlets</span>
                  <span className={`text-[0.6rem] px-1.5 py-0.5 rounded font-semibold ml-auto
                    ${K4_Open ? 'bg-red-100 text-red-700' : controlMode === 'failsafe' ? 'bg-orange-100 text-orange-700' : 'bg-green-100 text-green-700'}`}>
                    {K4_Open ? 'OPEN' : controlMode === 'failsafe' ? 'CLOSED (island)' : 'CLOSED'}
                  </span>
                </div>
                <p className="text-[0.65rem] text-slate-600 mt-1 leading-relaxed">
                  Controls outlet connection. CLOSED on all modes except Load Cut Off.
                  <span className="text-red-600 font-medium"> OPEN only on Shutdown.</span>
                </p>
                <p className="text-[0.6rem] text-slate-400 mt-0.5">
                  Battery protection: Hybrid Inverter (auto) + MCCB (admin). K4 is NOT a battery protector.
                </p>
              </div>
            </div>

            {/* K1 */}
            <div className="flex items-start gap-3 px-4 py-3 hover:bg-amber-50 transition-colors">
              <div className={`mt-0.5 w-8 h-8 rounded-full flex items-center justify-center shrink-0 ${K1_Solar ? 'bg-amber-100' : 'bg-slate-100'}`}>
                <Sun className={`w-4 h-4 ${K1_Solar ? 'text-amber-600' : 'text-slate-400'}`} />
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 flex-wrap">
                  <span className="text-xs font-bold text-slate-800">K1</span>
                  <span className="text-[0.6rem] px-1.5 py-0.5 rounded bg-amber-100 text-amber-700">Solar Priority</span>
                  <span className={`text-[0.6rem] px-1.5 py-0.5 rounded font-semibold ml-auto ${K1_Solar ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-500'}`}>
                    {K1_Solar ? 'ACTIVE' : 'STANDBY'}
                  </span>
                </div>
                <p className="text-[0.65rem] text-slate-600 mt-1">Inverter AC Out → ATS-A → K4 → Outlets.</p>
                {K1_Solar && (
                  <div className="mt-1 text-[0.6rem] text-amber-700 font-medium">
                    ⚡ {inverterVoltage.toFixed(1)}V / {inverterFrequency.toFixed(1)}Hz → outlets energized
                  </div>
                )}
              </div>
            </div>

            {/* K2 */}
            <div className="flex items-start gap-3 px-4 py-3 hover:bg-blue-50 transition-colors">
              <div className={`mt-0.5 w-8 h-8 rounded-full flex items-center justify-center shrink-0 ${K2_Grid ? 'bg-blue-100' : 'bg-slate-100'}`}>
                <Zap className={`w-4 h-4 ${K2_Grid ? 'text-blue-600' : 'text-slate-400'}`} />
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 flex-wrap">
                  <span className="text-xs font-bold text-slate-800">K2</span>
                  <span className="text-[0.6rem] px-1.5 py-0.5 rounded bg-blue-100 text-blue-700">Grid Bypass</span>
                  <span className={`text-[0.6rem] px-1.5 py-0.5 rounded font-semibold ml-auto ${K2_Grid ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-500'}`}>
                    {K2_Grid ? 'ACTIVE' : 'STANDBY'}
                  </span>
                </div>
                <p className="text-[0.65rem] text-slate-600 mt-1">Grid → ATS-B → K4 → Outlets.</p>
                {K2_Grid && (
                  <div className="mt-1 text-[0.6rem] text-blue-700 font-medium">
                    ⚡ {gridVoltage.toFixed(1)}V / {gridFrequency.toFixed(1)}Hz → outlets energized
                  </div>
                )}
              </div>
            </div>

            {/* K3 */}
            <div className="flex items-start gap-3 px-4 py-3 hover:bg-teal-50 transition-colors">
              <div className={`mt-0.5 w-8 h-8 rounded-full flex items-center justify-center shrink-0
                ${k3Reconnect.locked ? 'bg-cyan-100' : K3_GridAssist && hasPowerSource ? 'bg-teal-100' : 'bg-slate-100'}`}>
                <ArrowLeftRight className={`w-4 h-4 ${k3Reconnect.locked ? 'text-cyan-600' : K3_GridAssist && hasPowerSource ? 'text-teal-600' : 'text-slate-400'}`} />
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 flex-wrap">
                  <span className="text-xs font-bold text-slate-800">K3</span>
                  <span className="text-[0.6rem] px-1.5 py-0.5 rounded bg-teal-100 text-teal-700">Grid Assist / Charging</span>
                  <span className="text-[0.6rem] px-1.5 py-0.5 rounded bg-slate-100 text-slate-500">Auto only</span>
                  <span className={`text-[0.6rem] px-1.5 py-0.5 rounded font-semibold ml-auto
                    ${k3Reconnect.locked ? 'bg-cyan-100 text-cyan-700'
                    : K3_GridAssist && hasPowerSource ? 'bg-teal-100 text-teal-700'
                    : 'bg-slate-100 text-slate-500'}`}>
                    {k3ModeLabel}
                  </span>
                </div>
                <p className="text-[0.65rem] text-slate-600 mt-1 leading-relaxed">
                  Grid Assist / Charges battery from grid when solar is low or battery is low
                  (bat &lt;{BAT_WARNING_LOW}V or solar &lt;{SOLAR_CRITICAL_LOW}W).
                  <span className="text-cyan-700 font-medium"> Requires K4 closed + K1 or K2 active.</span>
                </p>
                {k3Reconnect.locked && (
                  <div className="mt-1 text-[0.6rem] text-cyan-700 font-medium flex items-center gap-1">
                    <Timer className="w-3 h-3" />
                    5-min stable grid required · {k3Reconnect.secondsRemaining}s remaining
                  </div>
                )}
                {K3_GridAssist && !k3Reconnect.locked && hasPowerSource && (
                  <div className={`mt-1 text-[0.6rem] font-medium ${k3IsCharging ? 'text-teal-700' : 'text-blue-700'}`}>
                    {k3IsCharging
                      ? `↑ Charging battery · Solar ${solarPower.toFixed(0)}W · ${batteryVoltage.toFixed(1)}V`
                      : `← Grid Assist · Battery ${batteryVoltage.toFixed(1)}V`}
                  </div>
                )}
              </div>
            </div>
          </div>

          {/* Quick reference footer */}
          <div className="px-4 py-3 bg-cyan-50 border-t border-cyan-200">
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-1.5 text-[0.6rem] text-slate-700">
              {[
                { dot: 'bg-green-500',  text: <><strong>K4 CLOSED + K1 ON</strong> → Solar path → outlets energized</> },
                { dot: 'bg-blue-500',   text: <><strong>K4 CLOSED + K2 ON</strong> → Grid bypass → outlets energized</> },
                { dot: 'bg-orange-400', text: <><strong>Failsafe</strong> → K4 CLOSED, K1+K2 OFF — island mode</> },
                { dot: 'bg-red-500',    text: <><strong>Load Cut Off</strong> → K4 OPEN — outlets physically disconnected</> },
              ].map((r, i) => (
                <div key={i} className="flex items-center gap-1.5">
                  <span className={`w-2 h-2 rounded-full shrink-0 ${r.dot}`} />
                  <span>{r.text}</span>
                </div>
              ))}
              <div className="flex items-center gap-1.5 sm:col-span-2">
                <span className="w-2 h-2 rounded-full shrink-0 bg-teal-500" />
                <span><strong>K3 auto:</strong> GRID ASSIST when bat low or solar critical · Requires K1 or K2 active · LOCKED 5min after grid fault</span>
              </div>
            </div>
          </div>
        </div>

        {/* ── ACTIVE MODE STATUS ── */}
        <div className={`p-3 rounded-lg border-2 ${
          controlMode === 'solar'    ? 'bg-amber-50 border-amber-300'   :
          controlMode === 'grid'     ? 'bg-blue-50 border-blue-300'     :
          controlMode === 'failsafe' ? 'bg-orange-50 border-orange-300' :
                                       'bg-red-50 border-red-300'}`}>
          <div className="text-xs text-slate-900 mb-1 font-semibold">
            Active Mode: <span className="font-normal">{modeDescription[controlMode]}</span>
          </div>
          <div className={`text-xs mt-1 font-semibold ${outletEnergized ? 'text-green-700' : 'text-red-700'}`}>
            🔌 Outlets:{' '}
            {outletEnergized
              ? (K1_Solar ? 'Powered via SOLAR (Inverter → K1)' : 'Powered via GRID BYPASS (K2)')
              : K4_Open ? 'DISCONNECTED — K4 OPEN (Load Cut Off)'
              : controlMode === 'failsafe' ? 'UNPOWERED — Failsafe island mode'
              : 'UNPOWERED — No active power path (K1 & K2 both OFF)'}
          </div>
          {controlMode === 'solar' && (
            <div className="text-xs text-amber-700 mt-1">
              Inverter {inverterVoltage.toFixed(1)}V / {inverterFrequency.toFixed(1)}Hz ·
              Battery {batteryVoltage.toFixed(1)}V ({batterySOC.toFixed(0)}%) ·
              Solar {solarPower.toFixed(0)}W ({solarPct}%)
            </div>
          )}
          {(controlMode === 'grid' || controlMode === 'failsafe') && (
            <div className={`text-xs mt-1 ${controlMode === 'failsafe' ? 'text-orange-700' : 'text-blue-700'}`}>
              {controlMode === 'failsafe'
                ? `Island mode — Battery ${batteryVoltage.toFixed(1)}V · No AC input`
                : `Grid ${gridVoltage.toFixed(1)}V / ${gridFrequency.toFixed(1)}Hz`}
            </div>
          )}
          {K3_GridAssist && hasPowerSource && (
            <div className="text-xs text-teal-700 mt-1">
              ⚡ K3 {k3IsCharging ? 'GRID CHARGING' : 'GRID ASSISTING'} —{' '}
              {k3IsCharging
                ? `Grid Assist Active · Battery ${batteryVoltage.toFixed(1)}V · Solar ${solarPower.toFixed(0)}W`
                : isNight ? `Night charging · Battery ${batteryVoltage.toFixed(1)}V`
                : solarLowDay || solarZeroDay
                  ? `${solarZeroDay ? 'No solar' : `Solar ${solarPower.toFixed(0)}W (low)`} · Charging ${batteryVoltage.toFixed(1)}V`
                : `Grid charging battery ${batteryVoltage.toFixed(1)}V (low)`}
            </div>
          )}
          {k3Reconnect.locked && (
            <div className="text-xs text-cyan-700 mt-1 flex items-center gap-1">
              <Timer className="w-3 h-3" />
              K3 reconnect timer: {k3Reconnect.secondsRemaining}s remaining
            </div>
          )}
        </div>

        {/* ── SSR STATISTICS ── */}
        <div className="p-4 rounded-lg border-2 border-purple-300" style={{background:'linear-gradient(to bottom right, #faf5ff, #eff6ff)'}}>
          <div className="flex items-center gap-2 mb-3">
            <TrendingUp className="w-4 h-4 text-purple-600" />
            <span className="text-sm font-semibold text-purple-900">SSR Statistics</span>
          </div>
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
            <div className="bg-white rounded-lg p-3 border border-purple-200">
              <div className="text-xs text-slate-500 mb-1">Total Switches</div>
              <div className="text-xl font-bold text-slate-900">{totalSwitches}</div>
            </div>
            <div className="bg-white rounded-lg p-3 border border-purple-200">
              <div className="text-xs text-slate-500 mb-1">Last Switch</div>
              <div className="text-xl font-bold text-slate-900">{lastSwitchTime}</div>
            </div>
          </div>
          {autoSwitchEnabled && (
            <>
              <div className="border-t border-purple-200 mb-3" />
              <div className="flex items-center gap-2 mb-2">
                <AlertCircle className="w-4 h-4 text-purple-600" />
                <span className="text-sm font-semibold text-purple-900">Auto-Switching Rules</span>
              </div>
              <div className="space-y-1.5">
                {[
                  { c: 'bg-amber-500',  l: 'Solar Priority (K1):',            d: `Inverter ${INV_CRITICAL_LOW}–${INV_CRITICAL_HIGH}V + bat ≥${BAT_WARNING_LOW}V` },
                  { c: 'bg-blue-500',   l: 'Grid Bypass (K2):',               d: `Inverter fault → auto switch to grid` },
                  { c: 'bg-orange-400', l: 'Failsafe (Island):',              d: 'K4 CLOSED, K1+K2 OFF — battery via inverter' },
                  { c: 'bg-violet-500', l: 'K3 Grid Assist (auto):',          d: `Bat low or Solar critical + K1/K2 active` },
                  { c: 'bg-yellow-500', l: 'K3 Grid Assist (auto):',      d: `Bat <${BAT_WARNING_LOW}V OR Solar <${SOLAR_CRITICAL_LOW}W + K1/K2 active` },
                  { c: 'bg-cyan-500',   l: 'K3 Reconnect Timer:', d: 'K3 locked 5min after grid fault' },
                  { c: 'bg-blue-300',   l: 'Manual Lockout (15s):',           d: 'Auto pauses 15s after any manual command — relay settling' },
                  { c: 'bg-red-500',    l: 'Load Cut Off (K4 OPEN):',         d: 'Manual or emergency. All loads cut.' },
                ].map((r, i) => (
                  <div key={i} className="flex items-center gap-2">
                    <div className={`w-1.5 h-1.5 rounded-full ${r.c} shrink-0`} />
                    <span className="text-xs text-slate-700"><strong>{r.l}</strong> {r.d}</span>
                  </div>
                ))}
              </div>
            </>
          )}
        </div>

        <div className="border-t-2 border-slate-200 my-2" />

        {/* ── OUTLET CONTROL ── */}
        <div className="space-y-3">
          <div className="flex items-center gap-2">
            <Power className="w-5 h-5 text-slate-700" />
            <h3 className="text-sm sm:text-base font-semibold text-slate-900">Outlet Control Panel</h3>
            <span className={`ml-auto text-[0.65rem] px-2 py-0.5 rounded-full font-bold border ${
              outletEnergized ? 'bg-green-100 text-green-700 border-green-300'
              : K4_Open ? 'bg-red-100 text-red-700 border-red-300'
              : controlMode === 'failsafe' ? 'bg-orange-100 text-orange-700 border-orange-300'
              : 'bg-slate-100 text-slate-700 border-slate-300'}`}>
              {outletEnergized ? (K1_Solar ? '⚡ SOLAR PATH' : '⚡ GRID PATH')
               : K4_Open ? '🔴 K4 OPEN — SHUTDOWN'
               : controlMode === 'failsafe' ? '🟠 FAILSAFE — ISLAND'
               : '⚫ NO PATH'}
            </span>
          </div>

          <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {outlets.map(outlet => {
              const isActive = outletEnergized;
              return (
                <div key={outlet.id} className={`p-3 sm:p-4 rounded-lg border-2 transition-all ${
                  isActive ? 'border-green-300' : 'bg-slate-50 border-slate-300'
                }`} style={isActive ? {background:'linear-gradient(to bottom right, #f0fdf4, #ecfdf5)'} : {}}>
                  <div className="flex items-center justify-between mb-3">
                    <div className="flex items-center gap-2">
                      <div className={`p-1.5 rounded-lg ${isActive ? 'bg-green-500' : 'bg-slate-400'}`}>
                        <Power className="w-3 h-3 sm:w-4 sm:h-4 text-white" />
                      </div>
                      <div>
                        <div className="text-xs sm:text-sm text-slate-900">{outlet.name}</div>
                        <div className="text-[0.6rem] sm:text-xs text-slate-500">{outlet.load}</div>
                      </div>
                    </div>
                    <span className={`px-2 py-1 rounded text-[0.65rem] border font-semibold ${
                      outletEnergized
                        ? 'bg-green-100 text-green-700 border-green-300'
                        : 'bg-slate-100 text-slate-400 border-slate-200'}`}>
                      {outletEnergized ? 'ON' : 'OFF'}
                    </span>
                  </div>
                  <div className={`px-3 py-2 rounded-lg mb-3 ${
                    outlet.source.includes('Grid')  ? 'bg-blue-100 border border-blue-300' :
                    outlet.source.includes('Solar') ? 'bg-amber-100 border border-amber-300' :
                                                      'bg-slate-200 border border-slate-300'}`}>
                    <div className="flex justify-between">
                      <span className="text-xs text-slate-500">Source:</span>
                      <span className={`text-xs font-medium ${
                        outlet.source.includes('Grid')  ? 'text-blue-900' :
                        outlet.source.includes('Solar') ? 'text-amber-900' : 'text-slate-700'}`}>
                        {outlet.source}
                      </span>
                    </div>
                  </div>
                  <div className="mb-3 flex items-center justify-between">
                    <span className="text-xs text-slate-500">Status:</span>
                    <span className={`text-xs px-3 py-1 rounded-md font-semibold ${isActive ? 'bg-green-500 text-white' : 'bg-gray-400 text-white'}`}>
                      {isActive ? 'ACTIVE' : 'INACTIVE'}
                    </span>
                  </div>
                  <div className="space-y-1.5 text-xs">
                    <div className="flex justify-between">
                      <span className="text-slate-500">Current:</span>
                      <span className="text-slate-900">{outlet.current.toFixed(2)} A</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-slate-500">Voltage:</span>
                      <span className="text-slate-900">{outlet.voltage.toFixed(1)} V</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-slate-500">Power:</span>
                      <span className="text-slate-900 font-semibold">{(outlet.current * outlet.voltage).toFixed(0)} W</span>
                    </div>
                  </div>
                  {outlet.hasAnomaly && isActive && (
                    <div className="mt-2 p-2 rounded bg-red-100 border border-red-300 flex items-center gap-1">
                      <AlertCircle className="w-3 h-3 text-red-600 shrink-0" />
                      <span className="text-[0.65rem] text-red-700">Anomaly on power source</span>
                    </div>
                  )}
                </div>
              );
            })}
          </div>

          {/* [PATCH-OUTLETS] Total load now reflects real sensor current */}
          <div className="p-3 rounded-lg border border-indigo-200" style={{background:'linear-gradient(to right, #eef2ff, #faf5ff)'}}>
            <div className="flex items-center justify-between">
              <span className="text-xs sm:text-sm text-slate-700">Total Load:</span>
              <div className="flex items-center gap-2">
                <span className="text-lg sm:text-xl font-bold text-indigo-900">
                  {(outletEnergized ? activeSourceCurrent : 0).toFixed(2)} A
                </span>
                <span className="text-xs text-slate-500">
                  ({(outletEnergized ? activeSourceCurrent * activeSourceVoltage : 0).toFixed(0)} W)
                </span>
              </div>
            </div>
          </div>
        </div>

      </CardContent>
    </Card>
  );
}
